{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 370,
  "data": {
    "url": "bom_temperature_anomaly.csv"
  },
  "facet": {
    "field": "state",
    "type": "nominal",
    "header": {
      "titleColor": "#ffffff",
      "labelColor": "#ffffff",
      "labelFontSize": 10,
      "labelFontWeight": "bold"
    }
  },
  "columns": 4,
  "spec": {
    "width": 130,
    "height": 80,
    "mark": {
      "type": "area",
      "color": "#E67E22",
      "opacity": 0.4,
      "line": {
        "color": "#E67E22",
        "strokeWidth": 1.5
      }
    },
    "encoding": {
      "x": {
        "field": "month",
        "type": "ordinal",
        "sort": [
          "Jan",
          "Feb",
          "Mar",
          "Apr",
          "May",
          "Jun",
          "Jul",
          "Aug",
          "Sep",
          "Oct",
          "Nov",
          "Dec"
        ],
        "title": null,
        "axis": {
          "labelAngle": -45,
          "labelFontSize": 8,
          "labelColor": "#aaaaaa",
          "grid": false,
          "domainColor": "#1e3a55",
          "tickColor": "#1e3a55"
        }
      },
      "y": {
        "field": "avg_fire_danger_index",
        "type": "quantitative",
        "title": null,
        "axis": {
          "labelFontSize": 8,
          "labelColor": "#aaaaaa",
          "gridColor": "#1a2a3a",
          "domainColor": "#1e3a55",
          "tickCount": 3
        }
      },
      "tooltip": [
        {
          "field": "state",
          "type": "nominal",
          "title": "State"
        },
        {
          "field": "month",
          "type": "ordinal",
          "title": "Month"
        },
        {
          "field": "avg_fire_danger_index",
          "type": "quantitative",
          "title": "Fire Danger Index",
          "format": ".1f"
        }
      ]
    }
  },
  "config": {
    "background": "#0a1628",
    "view": {
      "stroke": "#1e3a55"
    },
    "facet": {
      "spacing": 12
    }
  }
}