{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 280,
  "data": {"url": "economic_losses.csv"},
  "resolve": {"scale": {"y": "independent"}},
  "layer": [
    {
      "mark": {"type": "line", "color": "#C0392B", "strokeWidth": 2.5,
               "point": {"filled": true, "color": "#C0392B", "size": 50}},
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "axis": {"labelAngle": -45, "labelFontSize": 9, "titleFontSize": 11, "grid": false}
        },
        "y": {
          "field": "temp_anomaly_c",
          "type": "quantitative",
          "title": "Temperature Anomaly (°C)",
          "axis": {"titleColor": "#C0392B", "labelColor": "#C0392B", "format": "+.2f", "titleFontSize": 11, "labelFontSize": 10}
        },
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "temp_anomaly_c", "type": "quantitative", "title": "Temp Anomaly (°C)", "format": "+.2f"},
          {"field": "rainfall_anomaly_mm", "type": "quantitative", "title": "Rainfall Anomaly (mm)", "format": ".1f"}
        ]
      }
    },
    {
      "mark": {"type": "bar", "color": "#E67E22", "opacity": 0.4},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {
          "field": "rainfall_anomaly_mm",
          "type": "quantitative",
          "title": "Rainfall Anomaly (mm)",
          "axis": {"orient": "right", "titleColor": "#2980B9", "labelColor": "#2980B9", "format": ".0f", "titleFontSize": 11, "labelFontSize": 10}
        },
        "color": {"value": "#2980B9"}
      }
    },
    {
      "data": {"values": [{"year": "2019"}]},
      "mark": {"type": "rule", "color": "#C0392B", "strokeDash": [4,3], "strokeWidth": 1.5},
      "encoding": {"x": {"field": "year", "type": "ordinal"}}
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": "transparent"}}
}
