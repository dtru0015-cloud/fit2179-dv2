{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {"url": "area_temp_combined.csv"},
  "vconcat": [
    {
      "title": {
        "text": "Drag the bottom chart to zoom",
        "color": "#888888",
        "fontSize": 10,
        "anchor": "end",
        "fontStyle": "italic"
      },
      "width": "container",
      "height": 230,
      "layer": [
        {
          "mark": {
            "type": "area",
            "color": "#E74C3C",
            "opacity": 0.25,
            "line": {"color": "#E74C3C", "strokeWidth": 1.5}
          },
          "encoding": {
            "x": {
              "field": "year",
              "type": "quantitative",
              "scale": {"domain": {"param": "brush"}},
              "title": null,
              "axis": {
                "format": "d",
                "labelColor": "#aaaaaa",
                "domainColor": "#1e3a55",
                "tickColor": "#1e3a55",
                "gridColor": "#1e2d45",
                "gridDash": [3,3]
              }
            },
            "y": {
              "field": "area_burned_million_ha",
              "type": "quantitative",
              "title": "Area Burned (M ha)",
              "axis": {
                "titleColor": "#E74C3C",
                "labelColor": "#E74C3C",
                "titleFontSize": 11,
                "labelFontSize": 9,
                "gridColor": "#1e2d45",
                "gridDash": [3,3],
                "domainColor": "#1e3a55"
              }
            },
            "tooltip": [
              {"field": "year", "type": "quantitative", "title": "Year", "format": "d"},
              {"field": "area_burned_million_ha", "type": "quantitative", "title": "Area Burned (M ha)", "format": ".2f"},
              {"field": "temp_anomaly", "type": "quantitative", "title": "Temp Anomaly (°C)", "format": "+.2f"}
            ]
          }
        },
        {
          "mark": {
            "type": "line",
            "color": "#3498DB",
            "strokeWidth": 2,
            "point": {"filled": true, "color": "#3498DB", "size": 40}
          },
          "encoding": {
            "x": {
              "field": "year",
              "type": "quantitative",
              "scale": {"domain": {"param": "brush"}}
            },
            "y": {
              "field": "temp_anomaly",
              "type": "quantitative",
              "title": "Temperature Anomaly (°C)",
              "axis": {
                "titleColor": "#3498DB",
                "labelColor": "#3498DB",
                "titleFontSize": 11,
                "labelFontSize": 9,
                "format": "+.1f",
                "orient": "right",
                "gridColor": "transparent",
                "domainColor": "#1e3a55"
              }
            }
          }
        }
      ],
      "resolve": {"scale": {"y": "independent"}}
    },
    {
      "width": "container",
      "height": 60,
      "params": [
        {
          "name": "brush",
          "select": {"type": "interval", "encodings": ["x"]}
        }
      ],
      "layer": [
        {
          "mark": {"type": "area", "color": "#E74C3C", "opacity": 0.3},
          "encoding": {
            "x": {
              "field": "year",
              "type": "quantitative",
              "title": "Year",
              "axis": {
                "format": "d",
                "labelColor": "#888888",
                "titleColor": "#888888",
                "titleFontSize": 10,
                "domainColor": "#1e3a55",
                "tickColor": "#1e3a55"
              }
            },
            "y": {
              "field": "area_burned_million_ha",
              "type": "quantitative",
              "title": "",
              "axis": null
            }
          }
        },
        {
          "mark": {"type": "line", "color": "#3498DB", "strokeWidth": 1.5},
          "encoding": {
            "x": {"field": "year", "type": "quantitative"},
            "y": {"field": "temp_anomaly", "type": "quantitative", "axis": null}
          }
        }
      ],
      "resolve": {"scale": {"y": "independent"}}
    }
  ],
  "config": {
    "background": "#0a1628",
    "font": "Inter, sans-serif",
    "view": {"stroke": "transparent"},
    "concat": {"spacing": 8}
  }
}
