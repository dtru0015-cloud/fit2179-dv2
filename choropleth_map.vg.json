{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 520,
  "height": 360,
  "title": {
    "text": "Bushfire Risk Across Australia",
    "fontSize": 22,
    "anchor": "middle",
    "color": "#111111"
  },

  "data": {
    "url": "australia_states.geojson",
    "format": {
      "type": "json",
      "property": "features"
    }
  },

  "transform": [
    {
      "lookup": "properties.STATE_NAME",
      "from": {
        "data": {
          "url": "bushfire_risk_by_state.csv"
        },
        "key": "state",
        "fields": [
          "fire_risk_score",
          "pct_land_fire_prone",
          "state_code",
          "label_lon",
          "label_lat"
        ]
      }
    }
  ],

  "projection": {
    "type": "mercator",
    "center": [134, -27],
    "scale": 520,
    "translate": [260, 180]
  },

  "layer": [
    {
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1
      },

      "encoding": {
        "color": {
          "field": "fire_risk_score",
          "type": "quantitative",
          "scale": {
            "scheme": "yelloworangered"
          },
          "title": "Fire Risk Score"
        },

        "tooltip": [
          {
            "field": "properties.STATE_NAME",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "fire_risk_score",
            "type": "quantitative",
            "title": "Risk Score"
          },
          {
            "field": "pct_land_fire_prone",
            "type": "quantitative",
            "title": "% Fire-prone Land"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "bold",
        "fill": "#111111"
      },

      "encoding": {
        "longitude": {
          "field": "label_lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "label_lat",
          "type": "quantitative"
        },
        "text": {
          "field": "state_code",
          "type": "nominal"
        }
      }
    }
  ]
}
