{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 320,

  "params": [
    { "name": "year_select",  "value": 2021 },
    { "name": "state_select", "value": null  }
  ],

  "projection": {
    "type": "mercator",
    "center": [134, -28],
    "scale": 550
  },

  "layer": [
    {
      "data": { "url": "bushfire_risk_by_state.csv" },
      "transform": [
        {
          "lookup": "state_code",
          "from": {
            "data": {
              "url": "australia_states.geojson",
              "format": { "type": "json", "property": "features" }
            },
            "key": "properties.state_code",
            "fields": ["geometry"]
          }
        },
        { "calculate": "datum.fire_risk_score / 100", "as": "risk_normalised" }
      ],
      "mark": { "type": "geoshape", "cursor": "pointer" },
      "encoding": {
        "shape": { "field": "geometry", "type": "geojson" },
        "color": {
          "field": "risk_normalised",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [0.5, 0.6, 0.7, 0.8],
            "range": ["#6b2c00", "#9c3a00", "#c43d00", "#e02010", "#ff2200"]
          },
          "legend": {
            "title": "Fire Risk",
            "titleFontSize": 11,
            "labelFontSize": 10,
            "format": ".0%",
            "titleColor": "#c8d8f0",
            "labelColor": "#8aabcc",
            "orient": "top-right"
          }
        },
        "stroke": {
          "condition": {
            "test": "state_select !== null && datum.state_code === state_select",
            "value": "#ffffff"
          },
          "value": "#2a4a7f"
        },
        "strokeWidth": {
          "condition": {
            "test": "state_select !== null && datum.state_code === state_select",
            "value": 2.5
          },
          "value": 0.8
        },
        "opacity": {
          "condition": {
            "test": "state_select === null || datum.state_code === state_select",
            "value": 1
          },
          "value": 0.2
        },
        "tooltip": [
          { "field": "state",              "type": "nominal",      "title": "State"              },
          { "field": "fire_risk_score",    "type": "quantitative", "title": "Risk Score"         },
          { "field": "pct_land_fire_prone","type": "quantitative", "title": "% Fire-Prone Land",
            "format": ".0f" }
        ]
      }
    },

    {
      "data": {
        "values": [
          { "state_code": "NSW", "lon": 146.5, "lat": -32.2 },
          { "state_code": "VIC", "lon": 144.5, "lat": -37.0 },
          { "state_code": "QLD", "lon": 145.0, "lat": -22.0 },
          { "state_code": "SA",  "lon": 135.5, "lat": -30.0 },
          { "state_code": "WA",  "lon": 121.5, "lat": -26.5 },
          { "state_code": "TAS", "lon": 146.5, "lat": -42.0 },
          { "state_code": "NT",  "lon": 133.0, "lat": -19.5 },
          { "state_code": "ACT", "lon": 149.1, "lat": -35.5 }
        ]
      },
      "mark": { "type": "text", "fontSize": 10, "fontWeight": "bold" },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "state_code", "type": "nominal" },
        "color": {
          "condition": {
            "test": "state_select !== null && datum.state_code === state_select",
            "value": "#ffffff"
          },
          "value": "#c8d8f0"
        },
        "opacity": {
          "condition": {
            "test": "state_select === null || datum.state_code === state_select",
            "value": 1
          },
          "value": 0.25
        }
      }
    }
  ],

  "config": {
    "view":       { "stroke": "transparent" },
    "background": "#0a1628",
    "font":       "Inter, sans-serif"
  }
}
