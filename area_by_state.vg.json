{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 280,
  "data": {"url": "bushfire_human_impact.csv"},
  "layer": [
    {
      "mark": {
        "type": "area",
        "color": "#E67E22",
        "opacity": 0.3,
        "line": {"color": "#E67E22", "strokeWidth": 2}
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "axis": {"labelAngle": -45, "labelFontSize": 9, "titleFontSize": 11, "grid": false}
        },
        "y": {
          "field": "area_ha",
          "type": "quantitative",
          "title": "Area Burned (ha)",
          "axis": {"format": "~s", "titleFontSize": 11, "labelFontSize": 10, "grid": true, "gridDash": [3,3]}
        }
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 60},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "area_ha", "type": "quantitative"},
        "color": {"value": "#E67E22"},
        "tooltip": [
          {"field": "event_name", "type": "nominal", "title": "Event"},
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "area_ha", "type": "quantitative", "title": "Area Burned (ha)", "format": ",.0f"},
          {"field": "deaths", "type": "quantitative", "title": "Deaths"},
          {"field": "homes", "type": "quantitative", "title": "Homes Destroyed"}
        ]
      }
    },
    {
      "data": {"values": [{"year": "2019", "label": "Black Summer"}]},
      "mark": {"type": "rule", "color": "#C0392B", "strokeDash": [4,3], "strokeWidth": 1.5},
      "encoding": {"x": {"field": "year", "type": "ordinal"}}
    },
    {
      "data": {"values": [{"year": "2019", "area_ha": 22000000, "label": "◀ Black Summer"}]},
      "mark": {"type": "text", "align": "left", "dx": 4, "dy": -8, "color": "#C0392B", "fontSize": 10, "fontWeight": "bold"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "area_ha", "type": "quantitative"},
        "text": {"field": "label"}
      }
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": "transparent"}}
}
