{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "data": {"url": "annual_area_burned.csv"},
  "layer": [
    {
      "mark": {
        "type": "area",
        "color": "#E67E22",
        "opacity": 0.3,
        "line": {"color": "#E67E22", "strokeWidth": 2}
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": "Year",
          "axis": {"labelAngle": -45, "labelFontSize": 9, "titleFontSize": 11, "grid": false}
        },
        "y": {
          "field": "total_area_ha",
          "type": "quantitative",
          "title": "Total Area Burned (ha)",
          "axis": {"format": "~s", "titleFontSize": 11, "labelFontSize": 10,
                   "grid": true, "gridDash": [3,3]}
        }
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 50, "color": "#E67E22"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "total_area_ha", "type": "quantitative"},
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "total_area_ha", "type": "quantitative", "title": "Area Burned (ha)", "format": ",.0f"},
          {"field": "notable_event", "type": "nominal", "title": "Notable Event"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.notable_event != ''"}],
      "mark": {
        "type": "text",
        "fontSize": 9,
        "fontWeight": "bold",
        "color": "#4a3f35",
        "angle": -35,
        "align": "left",
        "dx": 4,
        "dy": -10
      },
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "total_area_ha", "type": "quantitative"},
        "text": {"field": "notable_event", "type": "nominal"}
      }
    },
    {
      "data": {"values": [{"year": "2019"}]},
      "mark": {"type": "rule", "color": "#C0392B", "strokeDash": [4,3], "strokeWidth": 1.5},
      "encoding": {"x": {"field": "year", "type": "ordinal"}}
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": "transparent"}}
}
