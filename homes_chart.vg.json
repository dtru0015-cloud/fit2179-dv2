{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "data": { "url": "bushfire_human_impact.csv" },
  "transform": [
    { "filter": "datum.homes > 0" },
    { "calculate": "sequence(1, ceil(datum.homes / 250) + 1)", "as": "seq" },
    { "flatten": ["seq"] }
  ],
  "mark": {
    "type": "text",
    "baseline": "middle",
    "fontSize": 18
  },
  "encoding": {
    "x": {
      "field": "seq",
      "type": "quantitative",
      "title": "Each 🏠 = 250 homes destroyed",
      "axis": {
        "titleColor": "#E67E22",
        "titleFontSize": 11,
        "labelColor": "#888888",
        "labelFontSize": 9,
        "grid": false,
        "tickMinStep": 1,
        "domain": false
      }
    },
    "y": {
      "field": "event_name",
      "type": "nominal",
      "sort": { "field": "homes", "order": "descending" },
      "title": null,
      "axis": {
        "labelColor": "#ffffff",
        "labelFontSize": 10,
        "labelLimit": 160,
        "ticks": false,
        "domain": false
      }
    },
    "text": { "value": "🏠" },
    "tooltip": [
      { "field": "event_name", "type": "nominal",      "title": "Event"                              },
      { "field": "year",       "type": "ordinal",       "title": "Year"                               },
      { "field": "homes",      "type": "quantitative",  "title": "Homes Destroyed", "format": ",.0f"  }
    ]
  },
  "config": {
    "background": "#0a1628",
    "view": { "stroke": "transparent" }
  }
}
