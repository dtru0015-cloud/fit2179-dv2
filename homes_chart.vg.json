{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "data": {
    "values": [
      {"event_name": "Black Summer",      "year": "2019", "homes": 3000},
      {"event_name": "Ash Wednesday",     "year": "1983", "homes": 2500},
      {"event_name": "Black Saturday",    "year": "2009", "homes": 2029},
      {"event_name": "Black Friday",      "year": "1939", "homes": 1300},
      {"event_name": "Yarloop",           "year": "2016", "homes": 181},
      {"event_name": "Black Christmas",   "year": "2001", "homes": 109},
      {"event_name": "Wooroloo",          "year": "2021", "homes": 86},
      {"event_name": "Tathra",            "year": "2018", "homes": 69},
      {"event_name": "Alpine Fires",      "year": "2003", "homes": 41},
      {"event_name": "Sampson Flat",      "year": "2015", "homes": 27}
    ]
  },
  "encoding": {
    "y": {
      "field": "event_name",
      "type": "nominal",
      "sort": null,
      "title": null,
      "axis": {
        "labelFontSize": 10,
        "labelColor": "#ffffff",
        "labelLimit": 180
      }
    }
  },
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 4 },
      "encoding": {
        "x": {
          "field": "homes",
          "type": "quantitative",
          "title": "Homes Destroyed",
          "axis": {
            "format": ",.0f",
            "titleFontSize": 11,
            "labelFontSize": 10,
            "titleColor": "#E67E22",
            "labelColor": "#aaaaaa",
            "grid": true,
            "gridDash": [3, 3],
            "gridColor": "#1a2a3a",
            "domainColor": "#1e3a55"
          }
        },
        "color": {
          "field": "homes",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [100, 500, 1500, 2500],
            "range": ["#f4a460", "#e07b39", "#c0392b", "#8b1a1a", "#5c0a0a"]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "event_name", "type": "nominal",     "title": "Event"           },
          { "field": "year",       "type": "ordinal",      "title": "Year"            },
          { "field": "homes",      "type": "quantitative", "title": "Homes Destroyed",
            "format": ",.0f" }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 5,
        "baseline": "middle",
        "fontSize": 10,
        "fontWeight": "bold",
        "color": "#E67E22"
      },
      "encoding": {
        "x": { "field": "homes", "type": "quantitative" },
        "text": { "field": "homes", "type": "quantitative", "format": ",.0f" }
      }
    }
  ],
  "config": {
    "background": "#0a1628",
    "view": { "stroke": "transparent" }
  }
}
