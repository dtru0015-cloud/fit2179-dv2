{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 240,
  "data": {"url": "bom_temperature_anomaly.csv"},
  "mark": {"type": "rect", "cornerRadius": 2},
  "encoding": {
    "x": {
      "field": "month",
      "type": "ordinal",
      "title": "Month",
      "sort": ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"],
      "axis": {"labelFontSize": 10, "titleFontSize": 11}
    },
    "y": {
      "field": "state",
      "type": "nominal",
      "title": null,
      "axis": {"labelFontSize": 10}
    },
    "color": {
      "field": "avg_fire_danger_index",
      "type": "quantitative",
      "title": "Fire Danger",
      "scale": {"type": "sequential", "scheme": "orangered"},
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "titleFontSize": 10,
        "labelFontSize": 9
      }
    },
    "tooltip": [
      {"field": "state", "type": "nominal", "title": "State"},
      {"field": "month", "type": "ordinal", "title": "Month"},
      {"field": "avg_fire_danger_index", "type": "quantitative", "title": "Avg Fire Danger Index", "format": ".1f"}
    ]
  },
  "config": {"background": "transparent", "view": {"stroke": "transparent"}}
}
