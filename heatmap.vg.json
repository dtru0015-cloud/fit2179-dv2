{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 370,
  "data": {
    "url": "bom_temperature_anomaly.csv"
  },
  "mark": {
    "type": "rect",
    "cornerRadius": 2
  },
  "encoding": {
    "x": {
      "field": "month",
      "type": "ordinal",
      "title": "Month",
      "sort": [
        "Jan",
        "Feb",
        "Mar",
        "Apr",
        "May",
        "Jun",
        "Jul",
        "Aug",
        "Sep",
        "Oct",
        "Nov",
        "Dec"
      ],
      "axis": {
        "labelFontSize": 10,
        "titleFontSize": 11,
        "labelColor": "#ffffff",
        "titleColor": "#ffffff"
      }
    },
    "y": {
      "field": "state",
      "type": "nominal",
      "title": null,
      "axis": {
        "labelFontSize": 10,
        "labelColor": "#ffffff"
      }
    },
    "color": {
      "field": "avg_fire_danger_index",
      "type": "quantitative",
      "title": "Fire Danger",
      "scale": {
        "type": "sequential",
        "scheme": "orangered"
      },
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "titleColor": "#ffffff",
        "labelColor": "#ffffff",
        "titleFontSize": 10,
        "labelFontSize": 9
      }
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "month",
        "type": "ordinal",
        "title": "Month"
      },
      {
        "field": "avg_fire_danger_index",
        "type": "quantitative",
        "title": "Fire Danger Index",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "background": "#0a1628",
    "view": {
      "stroke": "transparent"
    }
  }
}