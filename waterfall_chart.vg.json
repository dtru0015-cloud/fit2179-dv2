{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 600,
  "height": 360,
  "padding": {"left": 60, "right": 20, "top": 20, "bottom": 80},
  "background": "#0a1628",

  "data": [
    {
      "name": "source",
      "values": [
        {"event": "Black Friday",    "year": 1939, "loss": 150,    "prev": 0,      "cumulative": 150,    "change": "+$150M",  "type": "small"},
        {"event": "Ash Wednesday",   "year": 1983, "loss": 950,    "prev": 150,    "cumulative": 1100,   "change": "+$950M",  "type": "medium"},
        {"event": "Black Saturday",  "year": 2009, "loss": 4400,   "prev": 1100,   "cumulative": 5500,   "change": "+$4.4B",  "type": "large"},
        {"event": "Other Events",    "year": null, "loss": 1065,   "prev": 5500,   "cumulative": 6565,   "change": "+$1.1B",  "type": "medium"},
        {"event": "Black Summer",    "year": 2019, "loss": 103000, "prev": 6565,   "cumulative": 109565, "change": "+$103B",  "type": "extreme"}
      ]
    }
  ],

  "scales": [
    {
      "name": "x",
      "type": "band",
      "domain": {"data": "source", "field": "event"},
      "range": "width",
      "padding": 0.2
    },
    {
      "name": "y",
      "type": "log",
      "domain": [100, 120000],
      "range": "height",
      "reverse": true,
      "nice": true
    },
    {
      "name": "color",
      "type": "ordinal",
      "domain": ["small", "medium", "large", "extreme"],
      "range": ["#2ecc71", "#3498db", "#e67e22", "#e74c3c"]
    }
  ],

  "axes": [
    {
      "orient": "bottom",
      "scale": "x",
      "labelColor": "#cccccc",
      "labelFontSize": 11,
      "labelFontWeight": "bold",
      "domainColor": "#1e3a55",
      "tickColor": "#1e3a55",
      "encode": {
        "labels": {
          "update": {
            "text": {"signal": "datum.value + (datum.value === 'Black Friday' ? ' (1939)' : datum.value === 'Ash Wednesday' ? ' (1983)' : datum.value === 'Black Saturday' ? ' (2009)' : datum.value === 'Black Summer' ? ' (2019)' : '')"},
            "angle": {"value": -25},
            "align": {"value": "right"}
          }
        }
      }
    },
    {
      "orient": "left",
      "scale": "y",
      "labelColor": "#aaaaaa",
      "labelFontSize": 10,
      "domainColor": "#1e3a55",
      "gridColor": "#1a2a3a",
      "gridDash": [3, 3],
      "title": "Cumulative Economic Loss (AUD)",
      "titleColor": "#ffffff",
      "titleFontSize": 11,
      "format": "$~s"
    }
  ],

  "marks": [
    {
      "type": "rect",
      "from": {"data": "source"},
      "encode": {
        "enter": {
          "x": {"scale": "x", "field": "event"},
          "width": {"scale": "x", "band": 1},
          "y": {"scale": "y", "field": "prev"},
          "y2": {"scale": "y", "field": "cumulative"},
          "fill": {"scale": "color", "field": "type"},
          "opacity": {"value": 0.9},
          "cornerRadius": {"value": 3},
          "tooltip": {
            "signal": "{'Event': datum.event + (datum.year ? ' (' + datum.year + ')' : ''), 'Added Loss': datum.change, 'Running Total': '$' + format(datum.cumulative, ',.0f') + 'M'}"
          }
        },
        "hover": {"opacity": {"value": 1}}
      }
    },
    {
      "type": "text",
      "from": {"data": "source"},
      "encode": {
        "enter": {
          "x": {"signal": "scale('x', datum.event) + bandwidth('x') / 2"},
          "y": {"scale": "y", "field": "prev", "offset": -8},
          "align": {"value": "center"},
          "fill": {"scale": "color", "field": "type"},
          "fontSize": {"value": 11},
          "fontWeight": {"value": "bold"},
          "text": {"field": "change"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "source"},
      "encode": {
        "enter": {
          "x": {"signal": "scale('x', datum.event) + bandwidth('x') / 2"},
          "y": {"scale": "y", "field": "cumulative", "offset": 14},
          "align": {"value": "center"},
          "fill": {"value": "#ffffff"},
          "fontSize": {"value": 10},
          "text": {"signal": "'$' + format(datum.cumulative / 1000, '.1f') + 'B'"}
        }
      }
    }
  ],

  "legends": [
    {
      "fill": "color",
      "orient": "bottom",
      "direction": "horizontal",
      "labelColor": "#ffffff",
      "titleColor": "#ffffff",
      "title": "Loss Scale",
      "encode": {
        "labels": {
          "update": {
            "text": {"signal": "datum.value === 'small' ? 'Small (<$1B)' : datum.value === 'medium' ? 'Significant ($1–5B)' : datum.value === 'large' ? 'Major ($5–10B)' : 'Catastrophic (>$100B)'"}
          }
        }
      }
    }
  ]
}
