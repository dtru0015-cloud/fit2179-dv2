{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 620,
  "height": 360,
  "padding": {"left": 70, "right": 20, "top": 40, "bottom": 90},
  "background": "#0a1628",

  "data": [
    {
      "name": "source",
      "values": [
        {"event": "Black Friday",   "year": "1939", "loss": 150,    "type": "small"},
        {"event": "Ash Wednesday",  "year": "1983", "loss": 950,    "type": "medium"},
        {"event": "Canberra Fires", "year": "2003", "loss": 300,    "type": "small"},
        {"event": "Black Saturday", "year": "2009", "loss": 4400,   "type": "large"},
        {"event": "Hazelwood",      "year": "2014", "loss": 650,    "type": "small"},
        {"event": "Sampson Flat",   "year": "2015", "loss": 15,     "type": "tiny"},
        {"event": "Yarloop",        "year": "2016", "loss": 200,    "type": "small"},
        {"event": "Tathra",         "year": "2018", "loss": 25,     "type": "tiny"},
        {"event": "Black Summer",   "year": "2019", "loss": 103000, "type": "extreme"},
        {"event": "Wooroloo",       "year": "2021", "loss": 50,     "type": "tiny"}
      ]
    }
  ],

  "scales": [
    {
      "name": "x",
      "type": "band",
      "domain": {"data": "source", "field": "event"},
      "range": "width",
      "padding": 0.25
    },
    {
      "name": "y",
      "type": "pow",
      "exponent": 0.35,
      "domain": [0, 110000],
      "range": [{"signal": "height"}, 0],
      "nice": false
    },
    {
      "name": "color",
      "type": "ordinal",
      "domain": ["tiny", "small", "medium", "large", "extreme"],
      "range": ["#27AE60", "#2980B9", "#3498DB", "#E67E22", "#C0392B"]
    }
  ],

  "axes": [
    {
      "orient": "bottom",
      "scale": "x",
      "labelColor": "#cccccc",
      "labelFontSize": 10,
      "labelFontWeight": "bold",
      "domainColor": "#1e3a55",
      "tickColor": "#1e3a55",
      "encode": {
        "labels": {
          "update": {
            "angle": {"value": -35},
            "align": {"value": "right"},
            "dy": {"value": 4}
          }
        }
      }
    },
    {
      "orient": "left",
      "scale": "y",
      "labelColor": "#aaaaaa",
      "labelFontSize": 9,
      "domainColor": "#1e3a55",
      "gridColor": "#1a2a3a",
      "gridDash": [3, 3],
      "title": "Economic Loss (AUD Million)",
      "titleColor": "#ffffff",
      "titleFontSize": 11,
      "titlePadding": 10,
      "values": [0, 50, 200, 500, 1000, 2000, 5000, 10000, 50000, 103000],
      "encode": {
        "labels": {
          "update": {
            "text": {
              "signal": "datum.value >= 1000 ? '$' + datum.value/1000 + 'B' : '$' + datum.value + 'M'"
            }
          }
        }
      }
    }
  ],

  "marks": [
    {
      "type": "rect",
      "from": {"data": "source"},
      "encode": {
        "enter": {
          "x": {"scale": "x", "field": "event", "offset": 1},
          "width": {"scale": "x", "band": 1, "offset": -2},
          "y": {"scale": "y", "field": "loss"},
          "y2": {"scale": "y", "value": 0},
          "fill": {"scale": "color", "field": "type"},
          "opacity": {"value": 0.9},
          "cornerRadius": {"value": 3},
          "tooltip": {
            "signal": "{'Event': datum.event + ' (' + datum.year + ')', 'Economic Loss': datum.loss >= 1000 ? '$' + format(datum.loss/1000, '.1f') + 'B' : '$' + datum.loss + 'M'}"
          }
        },
        "hover": {"opacity": {"value": 1}}
      }
    },
    {
      "type": "text",
      "from": {"data": "source"},
      "encode": {
        "enter": {
          "x": {"signal": "scale('x', datum.event) + bandwidth('x') / 2"},
          "y": {"scale": "y", "field": "loss", "offset": -8},
          "align": {"value": "center"},
          "fill": {"scale": "color", "field": "type"},
          "fontSize": {"signal": "datum.type === 'extreme' ? 13 : datum.type === 'large' ? 11 : 9"},
          "fontWeight": {"value": "bold"},
          "text": {
            "signal": "datum.loss >= 1000 ? '$' + format(datum.loss/1000, '.1f') + 'B' : '$' + datum.loss + 'M'"
          }
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "source"},
      "encode": {
        "enter": {
          "x": {"signal": "scale('x', datum.event) + bandwidth('x') / 2"},
          "y": {"signal": "height + 70"},
          "align": {"value": "center"},
          "fill": {"value": "#666666"},
          "fontSize": {"value": 9},
          "fontStyle": {"value": "italic"},
          "text": {"field": "year"}
        }
      }
    }
  ],

  "legends": [
    {
      "fill": "color",
      "orient": "bottom",
      "direction": "horizontal",
      "labelColor": "#ffffff",
      "titleColor": "#ffffff",
      "labelFontSize": 10,
      "title": "Loss Scale",
      "titleFontSize": 10,
      "padding": 8,
      "encode": {
        "labels": {
          "update": {
            "text": {
              "signal": "datum.value === 'tiny' ? 'Minor (<$100M)' : datum.value === 'small' ? 'Moderate ($100M–$1B)' : datum.value === 'medium' ? 'Significant ($1–5B)' : datum.value === 'large' ? 'Major ($5–10B)' : 'Catastrophic (>$100B)'"
            }
          }
        }
      }
    }
  ]
}
