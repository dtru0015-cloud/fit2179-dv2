{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 620,
  "height": 360,
  "padding": {"left": 65, "right": 20, "top": 40, "bottom": 90},
  "background": "#0a1628",

  "data": [
    {
      "name": "source",
      "values": [
        {"event": "Black Friday",    "year": "1939", "loss": 150,    "prev": 0,      "cumulative": 150,    "change": "+$150M",  "type": "small"},
        {"event": "Ash Wednesday",   "year": "1983", "loss": 950,    "prev": 150,    "cumulative": 1100,   "change": "+$950M",  "type": "medium"},
        {"event": "Canberra Fires",  "year": "2003", "loss": 300,    "prev": 1100,   "cumulative": 1400,   "change": "+$300M",  "type": "small"},
        {"event": "Black Saturday",  "year": "2009", "loss": 4400,   "prev": 1400,   "cumulative": 5800,   "change": "+$4.4B",  "type": "large"},
        {"event": "Hazelwood",       "year": "2014", "loss": 650,    "prev": 5800,   "cumulative": 6450,   "change": "+$650M",  "type": "small"},
        {"event": "Sampson Flat",    "year": "2015", "loss": 15,     "prev": 6450,   "cumulative": 6465,   "change": "+$15M",   "type": "tiny"},
        {"event": "Yarloop",         "year": "2016", "loss": 200,    "prev": 6465,   "cumulative": 6665,   "change": "+$200M",  "type": "small"},
        {"event": "Tathra",          "year": "2018", "loss": 25,     "prev": 6665,   "cumulative": 6690,   "change": "+$25M",   "type": "tiny"},
        {"event": "Black Summer",    "year": "2019", "loss": 103000, "prev": 6690,   "cumulative": 109690, "change": "+$103B",  "type": "extreme"},
        {"event": "Wooroloo",        "year": "2021", "loss": 50,     "prev": 109690, "cumulative": 109740, "change": "+$50M",   "type": "tiny"}
      ]
    }
  ],

  "scales": [
    {
      "name": "x",
      "type": "band",
      "domain": {"data": "source", "field": "event"},
      "range": "width",
      "padding": 0.25
    },
    {
      "name": "y",
      "type": "linear",
      "domain": [0, 115000],
      "range": "height",
      "reverse": true,
      "nice": true
    },
    {
      "name": "color",
      "type": "ordinal",
      "domain": ["tiny", "small", "medium", "large", "extreme"],
      "range": ["#27AE60", "#2980B9", "#3498DB", "#E67E22", "#C0392B"]
    }
  ],

  "axes": [
    {
      "orient": "bottom",
      "scale": "x",
      "labelColor": "#cccccc",
      "labelFontSize": 10,
      "labelFontWeight": "bold",
      "domainColor": "#1e3a55",
      "tickColor": "#1e3a55",
      "encode": {
        "labels": {
          "update": {
            "angle": {"value": -35},
            "align": {"value": "right"},
            "dy": {"value": 4}
          }
        }
      }
    },
    {
      "orient": "left",
      "scale": "y",
      "labelColor": "#aaaaaa",
      "labelFontSize": 9,
      "domainColor": "#1e3a55",
      "gridColor": "#1a2a3a",
      "gridDash": [3, 3],
      "title": "Cumulative Economic Loss (AUD Million)",
      "titleColor": "#ffffff",
      "titleFontSize": 11,
      "titlePadding": 10,
      "format": "$,.0f"
    }
  ],

  "marks": [
    {
      "type": "rect",
      "from": {"data": "source"},
      "encode": {
        "enter": {
          "x": {"scale": "x", "field": "event", "offset": 1},
          "width": {"scale": "x", "band": 1, "offset": -2},
          "fill": {"scale": "color", "field": "type"},
          "opacity": {"value": 0.9},
          "cornerRadius": {"value": 3},
          "tooltip": {
            "signal": "{'Event': datum.event + ' (' + datum.year + ')', 'Added Loss': datum.change, 'Running Total': '$' + format(datum.cumulative, ',.0f') + 'M'}"
          }
        },
        "update": {
          "y": {"scale": "y", "field": "cumulative"},
          "y2": {
            "signal": "max(scale('y', datum.prev), scale('y', datum.cumulative) + 6)"
          }
        },
        "hover": {"opacity": {"value": 1}}
      }
    },
    {
      "type": "text",
      "from": {"data": "source"},
      "encode": {
        "enter": {
          "x": {"signal": "scale('x', datum.event) + bandwidth('x') / 2"},
          "align": {"value": "center"},
          "fill": {"scale": "color", "field": "type"},
          "fontSize": {"signal": "datum.type === 'extreme' ? 13 : 10"},
          "fontWeight": {"value": "bold"},
          "text": {"field": "change"}
        },
        "update": {
          "y": {"scale": "y", "field": "cumulative", "offset": -10}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "source"},
      "encode": {
        "enter": {
          "x": {"signal": "scale('x', datum.event) + bandwidth('x') / 2"},
          "align": {"value": "center"},
          "fill": {"value": "#666666"},
          "fontSize": {"value": 9},
          "text": {"field": "year"}
        },
        "update": {
          "y": {"signal": "height + 72"}
        }
      }
    }
  ],

  "legends": [
    {
      "fill": "color",
      "orient": "bottom",
      "direction": "horizontal",
      "labelColor": "#ffffff",
      "titleColor": "#ffffff",
      "labelFontSize": 10,
      "title": "Loss Scale",
      "titleFontSize": 10,
      "padding": 8,
      "encode": {
        "labels": {
          "update": {
            "text": {
              "signal": "datum.value === 'tiny' ? 'Minor (<$100M)' : datum.value === 'small' ? 'Moderate ($100M–$1B)' : datum.value === 'medium' ? 'Significant ($1–5B)' : datum.value === 'large' ? 'Major ($5–10B)' : 'Catastrophic (>$100B)'"
            }
          }
        }
      }
    }
  ]
}
