          "legend": {
            "title": "Event Type",
            "labelColor": "#ffffff", "titleColor": "#ffffff",
            "labelExpr": "datum.value === 'loss' ? 'Other Events' : 'Black Summer'",
            "orient": "top-right"
          }
        },
        "tooltip": [
          {"field": "event", "type": "nominal", "title": "Event"},
          {"field": "loss", "type": "quantitative", "title": "Loss (AUD M)", "format": "$,.0f"},
          {"field": "cumulative", "type": "quantitative", "title": "Running Total", "format": "$,.0f"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.type === 'black_summer'"}],
      "mark": {"type": "text", "align": "center", "dy": -10, "fontSize": 11, "fontWeight": "bold", "color": "#C0392B"},
      "encoding": {
        "x": {"field": "event", "type": "ordinal", "sort": null},
        "y": {"field": "cumulative", "type": "quantitative", "scale": {"type": "log", "base": 10, "domainMin": 1}},
