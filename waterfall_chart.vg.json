  "layer": [
    {
      "mark": {"type": "bar"},
      "encoding": {
        "x": {
          "field": "event", "type": "ordinal", "sort": null, "title": null,
          "axis": {"labelAngle": -30, "labelFontSize": 9, "labelColor": "#aaaaaa",
                   "grid": false, "domainColor": "#1e3a55"}
        },
        "y": {
          "field": "prev", "type": "quantitative",
          "title": "Cumulative Loss (AUD Million)",
