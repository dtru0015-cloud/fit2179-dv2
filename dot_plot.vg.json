{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 320,
  "data": {"url": "bushfire_human_impact.csv"},
  "layer": [
    {
      "mark": {"type": "bar", "opacity": 0.85, "cornerRadiusEnd": 3},
      "encoding": {
        "y": {
          "field": "event_name",
          "type": "nominal",
          "title": null,
          "sort": {"field": "homes", "order": "descending"},
          "axis": {"labelFontSize": 10, "labelLimit": 160, "labelColor": "#ffffff"}
        },
        "x": {
          "field": "homes",
          "type": "quantitative",
          "title": "Deaths (red dot) vs Homes Destroyed (orange bar)",
          "axis": {"format": ",.0f", "titleFontSize": 10, "labelFontSize": 10,
                   "titleColor": "#ffffff", "labelColor": "#aaaaaa",
                   "grid": true, "gridDash": [3,3], "gridColor": "#1a2a3a",
                   "domainColor": "#1e3a55"}
        },
        "color": {"value": "#E67E22"},
        "tooltip": [
          {"field": "event_name", "type": "nominal", "title": "Event"},
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "homes", "type": "quantitative", "title": "Homes Destroyed", "format": ",.0f"},
          {"field": "deaths", "type": "quantitative", "title": "Deaths"},
          {"field": "area_ha", "type": "quantitative", "title": "Area Burned (ha)", "format": ",.0f"}
        ]
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 80, "opacity": 0.9},
      "encoding": {
        "y": {"field": "event_name", "type": "nominal",
              "sort": {"field": "homes", "order": "descending"}},
        "x": {"field": "deaths", "type": "quantitative"},
        "color": {"value": "#C0392B"},
        "tooltip": [
          {"field": "event_name", "type": "nominal", "title": "Event"},
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "deaths", "type": "quantitative", "title": "Deaths"},
          {"field": "homes", "type": "quantitative", "title": "Homes Destroyed", "format": ",.0f"}
        ]
      }
    }
  ],
  "resolve": {"scale": {"x": "shared"}},
  "config": {"background": "#0a1628", "view": {"stroke": "transparent"}}
}
