{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 280,
  "data": {"url": "bushfire_human_impact.csv"},
  "layer": [
    {
      "mark": {"type": "rule", "strokeWidth": 2, "color": "#ccc"},
      "encoding": {
        "y": {"field": "event_name", "type": "nominal", "sort": {"field": "year"}, "title": null},
        "x": {"field": "deaths_direct", "type": "quantitative"},
        "x2": {"field": "homes_destroyed"}
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 80},
      "encoding": {
        "y": {"field": "event_name", "type": "nominal", "sort": {"field": "year"}, "title": null, "axis": {"labelFontSize": 9}},
        "x": {
          "field": "deaths_direct",
          "type": "quantitative",
          "title": "Deaths (red) vs Homes Destroyed (orange)",
          "axis": {"labelFontSize": 9}
        },
        "color": {"value": "#C0392B"},
        "tooltip": [
          {"field": "event_name", "type": "nominal", "title": "Event"},
          {"field": "year", "type": "quantitative", "title": "Year"},
          {"field": "deaths_direct", "type": "quantitative", "title": "Direct Deaths"}
        ]
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 80},
      "encoding": {
        "y": {"field": "event_name", "type": "nominal", "sort": {"field": "year"}},
        "x": {
          "field": "homes_destroyed",
          "type": "quantitative"
        },
        "color": {"value": "#E67E22"},
        "tooltip": [
          {"field": "event_name", "type": "nominal", "title": "Event"},
          {"field": "year", "type": "quantitative", "title": "Year"},
          {"field": "homes_destroyed", "type": "quantitative", "title": "Homes Destroyed", "format": ","}
        ]
      }
    }
  ],
  "config": {"font": "Inter, sans-serif", "view": {"stroke": "transparent"}}
}
