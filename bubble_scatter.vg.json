{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "data": {"url": "economic_losses.csv"},
  "params": [
    {
      "name": "event_select",
      "select": {"type": "point", "on": "mouseover", "nearest": true}
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "circle",
        "opacity": 0.85,
        "stroke": "#ffffff",
        "strokeWidth": 0.5
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "title": "Year",
          "scale": {"zero": false},
          "axis": {
            "format": "d",
            "titleFontSize": 11,
            "labelFontSize": 9,
            "titleColor": "#ffffff",
            "labelColor": "#aaaaaa",
            "gridColor": "#1e2d45",
            "gridDash": [3,3],
            "domainColor": "#1e3a55"
          }
        },
        "y": {
          "field": "economic_loss_aud_million",
          "type": "quantitative",
          "title": "Economic Loss (AUD Million)",
          "scale": {"type": "log"},
          "axis": {
            "format": "$,.0f",
            "titleFontSize": 11,
            "labelFontSize": 9,
            "titleColor": "#ffffff",
            "labelColor": "#aaaaaa",
            "gridColor": "#1e2d45",
            "gridDash": [3,3],
            "domainColor": "#1e3a55"
          }
        },
        "size": {
          "field": "homes_destroyed",
          "type": "quantitative",
          "title": "Homes destroyed",
          "scale": {"range": [40, 2000]},
          "legend": {
            "labelColor": "#cccccc",
            "titleColor": "#ffffff",
            "labelFontSize": 9,
            "titleFontSize": 10
          }
        },
        "color": {
          "field": "economic_loss_aud_million",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [100, 1000, 5000, 50000],
            "range": ["#FDDBC7","#F4A582","#D6604D","#B2182B","#67001F"]
          },
          "legend": null
        },
        "opacity": {
          "condition": {"param": "event_select", "value": 1},
          "value": 0.35
        },
        "tooltip": [
          {"field": "event_name", "type": "nominal", "title": "Event"},
          {"field": "year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "economic_loss_aud_million", "type": "quantitative", "title": "Economic Loss (AUD M)", "format": "$,.0f"},
          {"field": "homes_destroyed", "type": "quantitative", "title": "Homes Destroyed", "format": ","},
          {"field": "deaths", "type": "quantitative", "title": "Deaths", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "dy": -6,
        "fontSize": 9,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "economic_loss_aud_million", "type": "quantitative", "scale": {"type": "log"}},
        "text": {
          "condition": {
            "param": "event_select",
            "field": "event_name",
            "type": "nominal"
          },
          "value": ""
        },
        "color": {"value": "#ffffff"}
      }
    }
  ],
  "config": {
    "background": "#0a1628",
    "font": "Inter, sans-serif",
    "view": {"stroke": "transparent"}
  }
}
