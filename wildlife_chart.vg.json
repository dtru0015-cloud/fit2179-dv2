{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 700,
  "height": 340,
  "background": "#0a1628",
  "padding": 10,

  "signals": [
    {
      "name": "selected",
      "value": null,
      "on": [
        {
          "events": "symbol:click",
          "update": "selected === datum.id ? null : datum.id"
        }
      ]
    }
  ],

  "data": [
    {
      "name": "circles",
      "values": [
        {"id": "reptiles", "label": "2.46b", "name": "🦎 Reptiles", "x": 148, "y": 180, "size": 38000, "color": "#C0392B"},
        {"id": "birds",    "label": "180m",  "name": "🦅 Birds",    "x": 380, "y":  90, "size": 7000,  "color": "#E67E22"},
        {"id": "mammals",  "label": "143m",  "name": "🦘 Mammals",  "x": 380, "y": 200, "size": 5500,  "color": "#F39C12"},
        {"id": "frogs",    "label": "51m",   "name": "🐸 Frogs",    "x": 380, "y": 295, "size": 2500,  "color": "#27AE60"}
      ]
    }
  ],

  "marks": [
    {
      "type": "symbol",
      "from": {"data": "circles"},
      "encode": {
        "enter": {
          "shape":  {"value": "circle"},
          "x":      {"field": "x"},
          "y":      {"field": "y"},
          "fill":   {"field": "color"},
          "cursor": {"value": "pointer"},
          "tooltip": {"signal": "{'Species': datum.name, 'Count': datum.label}"}
        },
        "update": {
          "size":        {"signal": "selected === datum.id ? datum.size * 1.12 : datum.size"},
          "opacity":     {"signal": "selected === null || selected === datum.id ? 1 : 0.25"},
          "stroke":      {"signal": "selected === datum.id ? '#ffffff' : '#0a1628'"},
          "strokeWidth": {"signal": "selected === datum.id ? 3 : 1"}
        }
      }
    },
    {
      "type": "symbol",
      "from": {"data": "circles"},
      "encode": {
        "enter": {
          "shape":   {"value": "circle"},
          "x":       {"field": "x"},
          "y":       {"field": "y"},
          "fill":    {"value": "transparent"},
          "stroke":  {"value": "transparent"},
          "cursor":  {"value": "pointer"}
        },
        "update": {
          "size": {"signal": "datum.size * 1.6"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "circles"},
      "interactive": false,
      "encode": {
        "enter": {
          "x":          {"field": "x"},
          "y":          {"field": "y", "offset": -7},
          "text":       {"field": "label"},
          "fill":       {"value": "#ffffff"},
          "fontSize":   {"signal": "datum.id === 'reptiles' ? 20 : 12"},
          "fontWeight": {"value": "bold"},
          "align":      {"value": "center"},
          "baseline":   {"value": "middle"}
        },
        "update": {
          "opacity": {"signal": "selected === null || selected === datum.id ? 1 : 0.3"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "circles"},
      "interactive": false,
      "encode": {
        "enter": {
          "x":        {"field": "x"},
          "y":        {"field": "y", "offset": 10},
          "text":     {"field": "name"},
          "fill":     {"value": "#ffffff"},
          "fontSize": {"signal": "datum.id === 'reptiles' ? 13 : 10"},
          "align":    {"value": "center"},
          "baseline": {"value": "middle"}
        },
        "update": {
          "opacity": {"signal": "selected === null || selected === datum.id ? 1 : 0.3"}
        }
      }
    }
  ]
}
