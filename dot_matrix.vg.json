{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "data": {
    "url": "bushfire_major_events.csv"
  },
  "mark": {
    "type": "point",
    "filled": true,
    "opacity": 0.85
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Census Year",
      "axis": {
        "labelColor": "#ffffff",
        "titleColor": "#ffffff",
        "labelFontSize": 11,
        "titleFontSize": 11,
        "grid": false,
        "domainColor": "#1e3a55"
      }
    },
    "y": {
      "field": "pop_in_high_risk_zones",
      "type": "quantitative",
      "title": "Population in High Risk Zones",
      "axis": {
        "format": "~s",
        "labelColor": "#aaaaaa",
        "titleColor": "#ffffff",
        "labelFontSize": 10,
        "titleFontSize": 11,
        "gridColor": "#1a2a3a",
        "domainColor": "#1e3a55"
      }
    },
    "color": {
      "field": "state",
      "type": "nominal",
      "title": "State",
      "scale": {
        "domain": [
          "New South Wales",
          "Victoria",
          "Queensland",
          "Western Australia",
          "South Australia",
          "Tasmania"
        ],
        "range": [
          "#E74C3C",
          "#E67E22",
          "#F1C40F",
          "#2980B9",
          "#27AE60",
          "#8E44AD"
        ]
      },
      "legend": {
        "labelColor": "#ffffff",
        "titleColor": "#ffffff",
        "labelFontSize": 10,
        "titleFontSize": 10
      }
    },
    "size": {
      "field": "pop_in_high_risk_zones",
      "type": "quantitative",
      "scale": {
        "range": [
          100,
          800
        ]
      },
      "legend": null
    },
    "tooltip": [
      {
        "field": "year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "pop_in_high_risk_zones",
        "type": "quantitative",
        "title": "Population at Risk",
        "format": ",.0f"
      },
      {
        "field": "pct_pop_high_risk",
        "type": "quantitative",
        "title": "% of State Pop.",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "background": "#0a1628",
    "view": {
      "stroke": "transparent"
    }
  }
}