{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "resolve": { "scale": { "color": "shared" } },
  "config": {
    "background": "#0a1628",
    "view":   { "stroke": "transparent" },
    "font":   "Inter, sans-serif",
    "concat": { "spacing": 6 },
    "title":  { "color": "#c8d8f0", "fontSize": 11, "fontWeight": 500, "offset": 4 }
  },
  "hconcat": [
    {
      "title": "1980–89",
      "width": 140, "height": 115,
      "projection": { "type": "mercator", "center": [134, -28], "scale": 200 },
      "data": { "url": "australia_states.geojson", "format": { "type": "json", "property": "features" } },
      "transform": [{
        "lookup": "properties.state_code",
        "from": {
          "data": { "url": "fire_return_interval.csv" },
          "key": "state_code",
          "fields": ["d1980", "state_name"]
        }
      },
      { "calculate": "datum.d1980", "as": "value" }],
      "mark": { "type": "geoshape", "stroke": "#0a1628", "strokeWidth": 0.8 },
      "encoding": {
        "shape": { "field": "geometry", "type": "geojson" },
        "color": {
          "field": "value", "type": "quantitative",
          "scale": {
            "domain": [5, 75],
            "range": ["#b2182b","#ef8a62","#fddbc7","#d1e5f0","#67a9cf","#2166ac"]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "state_name", "type": "nominal",      "title": "State"             },
          { "field": "value",      "type": "quantitative", "title": "Avg yrs since fire", "format": ".0f" }
        ]
      }
    },
    {
      "title": "1990–99",
      "width": 140, "height": 115,
      "projection": { "type": "mercator", "center": [134, -28], "scale": 200 },
      "data": { "url": "australia_states.geojson", "format": { "type": "json", "property": "features" } },
      "transform": [{
        "lookup": "properties.state_code",
        "from": {
          "data": { "url": "fire_return_interval.csv" },
          "key": "state_code",
          "fields": ["d1990", "state_name"]
        }
      },
      { "calculate": "datum.d1990", "as": "value" }],
      "mark": { "type": "geoshape", "stroke": "#0a1628", "strokeWidth": 0.8 },
      "encoding": {
        "shape": { "field": "geometry", "type": "geojson" },
        "color": {
          "field": "value", "type": "quantitative",
          "scale": {
            "domain": [5, 75],
            "range": ["#b2182b","#ef8a62","#fddbc7","#d1e5f0","#67a9cf","#2166ac"]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "state_name", "type": "nominal",      "title": "State"             },
          { "field": "value",      "type": "quantitative", "title": "Avg yrs since fire", "format": ".0f" }
        ]
      }
    },
    {
      "title": "2000–09",
      "width": 140, "height": 115,
      "projection": { "type": "mercator", "center": [134, -28], "scale": 200 },
      "data": { "url": "australia_states.geojson", "format": { "type": "json", "property": "features" } },
      "transform": [{
        "lookup": "properties.state_code",
        "from": {
          "data": { "url": "fire_return_interval.csv" },
          "key": "state_code",
          "fields": ["d2000", "state_name"]
        }
      },
      { "calculate": "datum.d2000", "as": "value" }],
      "mark": { "type": "geoshape", "stroke": "#0a1628", "strokeWidth": 0.8 },
      "encoding": {
        "shape": { "field": "geometry", "type": "geojson" },
        "color": {
          "field": "value", "type": "quantitative",
          "scale": {
            "domain": [5, 75],
            "range": ["#b2182b","#ef8a62","#fddbc7","#d1e5f0","#67a9cf","#2166ac"]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "state_name", "type": "nominal",      "title": "State"             },
          { "field": "value",      "type": "quantitative", "title": "Avg yrs since fire", "format": ".0f" }
        ]
      }
    },
    {
      "title": "2010–19",
      "width": 140, "height": 115,
      "projection": { "type": "mercator", "center": [134, -28], "scale": 200 },
      "data": { "url": "australia_states.geojson", "format": { "type": "json", "property": "features" } },
      "transform": [{
        "lookup": "properties.state_code",
        "from": {
          "data": { "url": "fire_return_interval.csv" },
          "key": "state_code",
          "fields": ["d2010", "state_name"]
        }
      },
      { "calculate": "datum.d2010", "as": "value" }],
      "mark": { "type": "geoshape", "stroke": "#0a1628", "strokeWidth": 0.8 },
      "encoding": {
        "shape": { "field": "geometry", "type": "geojson" },
        "color": {
          "field": "value", "type": "quantitative",
          "scale": {
            "domain": [5, 75],
            "range": ["#b2182b","#ef8a62","#fddbc7","#d1e5f0","#67a9cf","#2166ac"]
          },
          "legend": {
            "title": "Avg years since last fire",
            "titleColor": "#c8d8f0", "labelColor": "#8aabcc",
            "titleFontSize": 10, "labelFontSize": 9,
            "orient": "right", "gradientLength": 120,
            "values": [5, 15, 30, 50, 75]
          }
        },
        "tooltip": [
          { "field": "state_name", "type": "nominal",      "title": "State"             },
          { "field": "value",      "type": "quantitative", "title": "Avg yrs since fire", "format": ".0f" }
        ]
      }
    }
  ]
}
