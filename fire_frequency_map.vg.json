{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "height": 370,
  "resolve": {
    "scale": {
      "color": "shared"
    }
  },
  "config": {
    "background": "#0a1628",
    "view": {
      "stroke": "transparent"
    },
    "font": "Inter, sans-serif",
    "concat": {
      "spacing": 12
    },
    "title": {
      "color": "#c8d8f0",
      "fontSize": 11,
      "fontWeight": 500,
      "offset": 4
    }
  },
  "hconcat": [
    {
      "title": "1980\u201389",
      "width": 160,
      "height": 280,
      "projection": {
        "type": "mercator",
        "center": [
          134,
          -28
        ],
        "scale": 240,
        "translate": [
          105,
          140
        ]
      },
      "data": {
        "url": "fire_return_interval.csv"
      },
      "transform": [
        {
          "lookup": "state_name",
          "from": {
            "data": {
              "url": "australia_states.geojson",
              "format": {
                "type": "json",
                "property": "features"
              }
            },
            "key": "properties.STATE_NAME",
            "fields": [
              "type",
              "geometry"
            ]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#0a1628",
        "strokeWidth": 0.8
      },
      "encoding": {
        "shape": {
          "field": "geometry",
          "type": "geojson"
        },
        "color": {
          "field": "d1980",
          "type": "quantitative",
          "scale": {
            "domain": [
              5,
              75
            ],
            "range": [
              "#b2182b",
              "#ef8a62",
              "#fddbc7",
              "#d1e5f0",
              "#67a9cf",
              "#2166ac"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "state_name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "d1980",
            "type": "quantitative",
            "title": "Avg yrs since fire",
            "format": ".0f"
          }
        ]
      }
    },
