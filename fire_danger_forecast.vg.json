  "encoding": {
    "x": {
      "field": "year", "type": "quantitative",
      "scale": {"domain": [1992, 2035]},
      "title": "Year",
      "axis": {
        "format": "d", "tickCount": 12,
        "labelColor": "#aaaaaa", "titleColor": "#ffffff",
        "labelFontSize": 10, "titleFontSize": 11,
        "gridColor": "#1a2a3a", "gridDash": [3,3],
        "domainColor": "#1e3a55"
      }
    }
  },
  "layer": [
    {
      "transform": [{"filter": "datum.type === 'historical'"}],
      "mark": {"type": "area", "interpolate": "monotone", "opacity": 0.9,
               "line": {"strokeWidth": 1.5, "opacity": 0.6}},
      "encoding": {
        "y": {
          "field": "count", "type": "quantitative", "stack": "zero",
          "title": "No. of States / Territories",
          "axis": {"labelColor": "#aaaaaa", "titleColor": "#ffffff",
                   "labelFontSize": 10, "titleFontSize": 11,
                   "gridColor": "#1a2a3a", "tickCount": 8}
        },
        "color": {
          "field": "category", "type": "nominal",
          "sort": ["Moderate", "High", "Extreme"],
          "scale": {"domain": ["Moderate","High","Extreme"],
                    "range": ["#27AE60","#E67E22","#C0392B"]},
          "legend": {"title": "Fire Danger Level", "orient": "top-right",
                     "labelColor": "#ffffff", "titleColor": "#ffffff",
                     "labelFontSize": 10, "titleFontSize": 10}
        },
        "order": {"field": "category", "sort": ["Moderate","High","Extreme"]},
        "tooltip": [
          {"field": "year",     "type": "quantitative", "title": "Year",         "format": "d"},
          {"field": "category", "type": "nominal",      "title": "Danger Level"},
          {"field": "count",    "type": "quantitative", "title": "No. of States"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.type === 'forecast'"}],
      "mark": {"type": "area", "interpolate": "monotone", "opacity": 0.4,
               "line": {"strokeWidth": 2, "opacity": 0.8, "strokeDash": [5,3]}},
      "encoding": {
        "y": {"field": "count", "type": "quantitative", "stack": "zero"},
        "color": {
          "field": "category", "type": "nominal",
          "sort": ["Moderate","High","Extreme"],
          "scale": {"domain": ["Moderate","High","Extreme"],
                    "range": ["#27AE60","#E67E22","#C0392B"]},
          "legend": null
        },
        "order": {"field": "category", "sort": ["Moderate","High","Extreme"]},
        "tooltip": [
          {"field": "year",     "type": "quantitative", "title": "Year (Projected)", "format": "d"},
          {"field": "category", "type": "nominal",      "title": "Danger Level"},
          {"field": "count",    "type": "quantitative", "title": "No. of States"}
        ]
      }
    },
    {
      "data": {"values": [{"year": 2024}]},
      "mark": {"type": "rule", "color": "#ffffff", "strokeDash": [4,3],
               "strokeWidth": 1.5, "opacity": 0.5},
      "encoding": {"x": {"field": "year", "type": "quantitative"}}
    },
    {
      "data": {"values": [{"year": 2023.5, "count": 7.7}]},
      "mark": {"type": "text", "align": "right", "fontSize": 9,
               "color": "#aaaaaa", "fontStyle": "italic"},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "count", "type": "quantitative"},
        "text": {"value": "◀ Historical"}
      }
    },
    {
      "data": {"values": [{"year": 2024.5, "count": 7.7}]},
      "mark": {"type": "text", "align": "left", "dx": 4, "fontSize": 9,
               "color": "#E67E22", "fontStyle": "italic"},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "count", "type": "quantitative"},
        "text": {"value": "Projected ▶"}
      }
    }
  ]
}
