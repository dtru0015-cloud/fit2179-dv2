        "type": "area",
        "interpolate": "monotone",
        "opacity": 0.9,
        "line": {"strokeWidth": 1.5, "opacity": 0.6}
      },
      "encoding": {
        "x": {
          "field": "year", "type": "quantitative",
          "scale": {"domain": [1992, 2035]},
          "title": "Year",
          "axis": {
            "labelColor": "#aaaaaa", "titleColor": "#ffffff",
            "labelFontSize": 10, "titleFontSize": 11,
            "gridColor": "#1a2a3a", "gridDash": [3,3],
            "format": "d", "tickCount": 12
          }
        },
        "y": {
          "field": "count", "type": "quantitative",
          "stack": "zero",
          "title": "No. of States / Territories",
          "axis": {
            "labelColor": "#aaaaaa", "titleColor": "#ffffff",
            "labelFontSize": 10, "titleFontSize": 11,
            "gridColor": "#1a2a3a", "tickCount": 8
          }
        },
        "color": {
          "field": "category", "type": "nominal",
          "sort": ["Moderate", "High", "Extreme"],
          "scale": {
            "domain": ["Moderate", "High", "Extreme"],
            "range": ["#27AE60", "#E67E22", "#C0392B"]
          },
          "legend": {
            "title": "Fire Danger Level",
            "labelColor": "#ffffff", "titleColor": "#ffffff",
            "labelFontSize": 10, "titleFontSize": 10,
            "orient": "top-right"
          }
        },
        "order": {"field": "category", "sort": ["Moderate", "High", "Extreme"]},
        "tooltip": [
          {"field": "year",     "type": "quantitative", "title": "Year"},
          {"field": "category", "type": "nominal",      "title": "Danger Level"},
          {"field": "count",    "type": "quantitative", "title": "No. of States"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.type === 'forecast'"}],
      "mark": {
        "type": "area",
        "interpolate": "monotone",
        "opacity": 0.45,
        "strokeDash": [5, 3],
        "line": {"strokeWidth": 2, "opacity": 0.8, "strokeDash": [5,3]}
      },
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "count", "type": "quantitative", "stack": "zero"},
        "color": {
          "field": "category", "type": "nominal",
          "sort": ["Moderate", "High", "Extreme"],
          "scale": {
            "domain": ["Moderate", "High", "Extreme"],
            "range": ["#27AE60", "#E67E22", "#C0392B"]
          },
          "legend": null
        },
        "order": {"field": "category", "sort": ["Moderate", "High", "Extreme"]},
        "tooltip": [
          {"field": "year",     "type": "quantitative", "title": "Year (Projected)"},
          {"field": "category", "type": "nominal",      "title": "Danger Level"},
          {"field": "count",    "type": "quantitative", "title": "No. of States"}
        ]
      }
    },
    {
      "data": {"values": [{"x": 2024}]},
      "mark": {"type": "rule", "color": "#ffffff", "strokeDash": [4,3], "strokeWidth": 1.5, "opacity": 0.5},
      "encoding": {"x": {"field": "x", "type": "quantitative"}}
    },
    {
      "data": {"values": [{"x": 2024.5, "y": 7.6, "label": "◀ Historical"}]},
