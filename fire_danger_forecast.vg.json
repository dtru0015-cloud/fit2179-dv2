  "layer": [
    {
      "transform": [{"filter": "datum.type === 'forecast'"}],
      "mark": {"type": "rect", "opacity": 0.07, "color": "#ffffff"},
      "encoding": {
        "x":  {"datum": 2024, "type": "quantitative"},
        "x2": {"datum": 2035},
        "y":  {"value": 0},
        "y2": {"value": 300}
      }
    },
    {
      "transform": [{"filter": "datum.type === 'historical'"}],
