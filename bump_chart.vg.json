{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 280,
  "data": {"url": "state_ranking_by_decade.csv"},
  "mark": {"type": "bar", "cornerRadiusEnd": 4},
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "title": null,
      "sort": {"field": "fire_risk_score", "order": "descending"},
      "axis": {"labelFontSize": 10, "labelColor": "#ffffff"}
    },
    "x": {
      "field": "fire_risk_score",
      "type": "quantitative",
      "title": "Fire Risk Score",
      "axis": {"titleFontSize": 11, "labelFontSize": 10, "titleColor": "#ffffff",
               "labelColor": "#aaaaaa", "grid": true, "gridColor": "#1a2a3a",
               "gridDash": [3,3], "domainColor": "#1e3a55"}
    },
    "color": {
      "field": "fire_risk_score",
      "type": "quantitative",
      "scale": {
        "type": "threshold",
        "domain": [40, 55, 65, 75],
        "range": ["#FDDBC7","#F4A582","#D6604D","#B2182B","#67001F"]
      },
      "legend": {"title": "Fire Risk Score", "titleColor": "#ffffff",
                 "labelColor": "#ffffff", "titleFontSize": 10, "labelFontSize": 10}
    },
    "tooltip": [
      {"field": "state", "type": "nominal", "title": "State"},
      {"field": "state_code", "type": "nominal", "title": "Code"},
      {"field": "fire_risk_score", "type": "quantitative", "title": "Fire Risk Score"},
      {"field": "pct_land_fire_prone", "type": "quantitative", "title": "% Land Fire-Prone"}
    ]
  },
  "config": {"background": "#0a1628", "view": {"stroke": "transparent"}}
}
